# ╔══════════════════════════════════════════════════════════════════╗
# ║  Can Antika — Production Environment Variables                  ║
# ║  Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.       ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=can_user
POSTGRES_PASSWORD=           # Güçlü şifre girin
POSTGRES_DB=can_antika_db
DB_URL=jdbc:postgresql://db:5432/can_antika_db?characterEncoding=UTF-8
DB_USERNAME=can_user
DB_PASSWORD=                 # POSTGRES_PASSWORD ile aynı

# ── Security ─────────────────────────────────────────────────────
JWT_SECRET=                  # En az 64 karakter random string (openssl rand -base64 64)
APP_ADMIN_PASSWORD=          # En az 12 karakter güçlü şifre

# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=              # Redis erişim şifresi

# ── URLs (Domain Ayarları) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.canantika.com   # Client-side API çağrıları (tarayıcıdan)
APP_FRONTEND_URL=https://canantika.com      # OAuth2 redirect & CORS
APP_BASE_URL=https://canantika.com          # Şifre sıfırlama linki base URL
APP_CORS_ALLOWED_ORIGINS=https://canantika.com,https://www.canantika.com

# ── Google OAuth2 ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=            # Google Cloud Console'dan
GOOGLE_CLIENT_SECRET=        # Google Cloud Console'dan

# ── Cloudinary (Görsel CDN) ──────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Resend (Email) ───────────────────────────────────────────────
RESEND_API_KEY=              # Resend dashboard'dan

# ── İsteğe Bağlı Ayarlar ────────────────────────────────────────
# COOKIE_SECURE=true         # Varsayılan: true (HTTPS zorunlu)
# SPRINGDOC_ENABLED=false    # Varsayılan: false (Swagger kapalı)
# JPA_DDL_AUTO=validate      # Varsayılan: validate
# FLYWAY_ENABLED=true        # Varsayılan: true
# ORDER_EXPIRY_HOURS=24      # Bekleyen sipariş iptal süresi (saat)
# STOCK_ALERT_THRESHOLD=5    # Düşük stok uyarı eşiği
# ADMIN_USER_ID=1            # Admin bildirim kullanıcı ID
